#!/usr/bin/env python3
"""
ClaudeKey — Whisper STT backend
Transcribes a WAV file using mlx-whisper (Apple Silicon optimized).
Falls back gracefully if mlx_whisper is not installed.

Usage:  whisper-stt <audio.wav> [model]
Output: transcribed text to stdout
Exit 0: success, Exit 1: unavailable/error

Install:
    pip install mlx-whisper

Models (fast → accurate):
    mlx-community/whisper-small           ~250MB  good balance
    mlx-community/whisper-medium          ~750MB  better
    mlx-community/whisper-large-v3-turbo  ~800MB  best (default)
"""

import sys
import os

def main():
    if len(sys.argv) < 2:
        print("Usage: whisper-stt <audio.wav> [model]", file=sys.stderr)
        sys.exit(1)

    audio_file = sys.argv[1]
    model = sys.argv[2] if len(sys.argv) > 2 else \
            os.environ.get("CLAUDEKEY_WHISPER_MODEL",
                           "mlx-community/whisper-large-v3-turbo")

    if not os.path.exists(audio_file):
        print(f"File not found: {audio_file}", file=sys.stderr)
        sys.exit(1)

    try:
        import mlx_whisper
    except ImportError:
        # Signal to caller that whisper is unavailable → fall back to SFSpeechRecognizer
        sys.exit(2)

    try:
        result = mlx_whisper.transcribe(
            audio_file,
            path_or_hf_repo=model,
            language=None,        # auto-detect: zh / en / mixed
            word_timestamps=False,
            verbose=False,
        )
        text = result.get("text", "").strip()
        if text:
            print(text)
            sys.exit(0)
        else:
            sys.exit(1)
    except Exception as e:
        print(f"Whisper error: {e}", file=sys.stderr)
        sys.exit(1)

if __name__ == "__main__":
    main()
