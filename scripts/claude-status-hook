#!/bin/bash
# ClaudeKey status hook wrapper
# Saves status JSON for ClaudeKeySoft, then passes through to claude-hud
#
# Install: replace statusLine.command in ~/.claude/settings.json with this script

read -r json 2>/dev/null || exit 0

# Save for ClaudeKeySoft to read
echo "$json" > /tmp/claudekey-status.json

# Also log for debugging (first 50 lines, then rotate)
echo "$json" >> /tmp/claudekey-status-log.jsonl
tail -50 /tmp/claudekey-status-log.jsonl > /tmp/claudekey-status-log.tmp 2>/dev/null
mv /tmp/claudekey-status-log.tmp /tmp/claudekey-status-log.jsonl 2>/dev/null

# Pass through to claude-hud (original statusLine command)
HUD_DIR=$(ls -td ~/.claude/plugins/cache/claude-hud/claude-hud/*/ 2>/dev/null | head -1)
if [ -n "$HUD_DIR" ]; then
    echo "$json" | "/Users/minbot/.local/share/fnm/node-versions/v24.14.0/installation/bin/node" "${HUD_DIR}dist/index.js"
else
    echo "ctx:?"
fi
